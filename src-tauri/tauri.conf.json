{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lightshot We Deserve",
  "version": "0.9.1",
  "identifier": "com.wolf.lightshotwedeserve",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["binaries/ffmpeg.exe"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "longDescription": "An open-source screenshot tool that lives in the Windows tray with global hotkeys for area and full-screen capture.",
    "shortDescription": "The Lightshot we deserve"
  }
}
